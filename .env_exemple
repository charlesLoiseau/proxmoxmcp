# ── Proxmox connection ─────────────────────────────────────────────────────────
PROXMOX_HOST=192.168.1.10
PROXMOX_PORT=8006
PROXMOX_USER=root@pam

# ── Auth: API token (recommended) ─────────────────────────────────────────────
PROXMOX_TOKEN_NAME=mcp
PROXMOX_TOKEN_VALUE=your-secret-token-value

# ── Auth: password (alternative, comment out token vars above if using this) ──
# PROXMOX_PASSWORD=your-password

# ── SSL ────────────────────────────────────────────────────────────────────────
# Set to true only if your Proxmox instance has a valid signed certificate
PROXMOX_VERIFY_SSL=false
